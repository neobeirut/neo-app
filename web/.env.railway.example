# Copy these into Railway Dashboard → Variables

# === DATABASE (Supabase — unchanged) ===
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# === AUTH ===
AUTH_SECRET=your_auth_secret_here
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://app.neobeirut.com

# === INFOBIP (WhatsApp OTP) ===
INFOBIP_API_KEY=your_infobip_api_key
INFOBIP_BASE_URL=https://XXXXX.api.infobip.com
INFOBIP_WHATSAPP_SENDER=+96176489078

# === EMAIL (Resend — optional, for admin password reset) ===
RESEND_API_KEY=your_resend_api_key

# === GOOGLE MAPS (optional) ===
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

# === CORS (allow mobile app to call this server) ===
CORS_ORIGINS=https://app.neobeirut.com,exp://192.168.18.226:8082
